---
// src/layouts/Layout.astro
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Poristiwa - Nadi Peristiwa Terkini" } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="robots" content="index, follow" />
  </head>
  <body class="bg-white text-gray-900 selection:bg-red-100 selection:text-red-900">
    <slot />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  :root {
    --accent: 224, 58, 58;
  }
  
  html {
    font-family: system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  /* News Typography */
  h1, h2, h3 {
    text-wrap: balance;
  }
</style>
