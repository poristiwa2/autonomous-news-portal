---
import Layout from '../../layouts/Layout.astro';
import HilltopAd from '../../components/HilltopAd.astro';

// 1. Generate paths for every JSON file found in the data folder
export async function getStaticPaths() {
  const articles = await Astro.glob('../../data/articles/*.json');
  
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

// Format the date for the Indonesian market
const publishDate = new Date(article.pubDate).toLocaleDateString('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit'
});
---

<Layout title={`${article.title} - Poristiwa`} description={article.content.substring(0, 160)}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    
    <nav class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-8">
      <a href="/" class="hover:text-red-600 transition-colors">Home</a>
      <span>/</span>
      <span class="text-red-600">{article.category}</span>
    </nav>

    <header class="mb-10">
      <h1 class="text-3xl md:text-5xl font-serif font-black text-gray-900 leading-[1.1] mb-6">
        {article.title}
      </h1>
      
      <div class="flex items-center justify-between border-y border-gray-100 py-4 text-xs text-gray-500">
        <div>
          Oleh <span class="font-bold text-gray-900">{article.source}</span>
        </div>
        <div>{publishDate} WIB</div>
      </div>
    </header>

    <HilltopAd zoneId="YOUR_ZONE_ID_TOP" height="90px" />

    <div class="prose prose-lg max-w-none font-sans leading-relaxed text-gray-800">
      <p class="first-letter:text-5xl first-letter:font-black first-letter:text-red-600 first-letter:mr-3 first-letter:float-left">
        {article.content}
      </p>
      
      <div class="mt-12 p-6 bg-gray-50 rounded-xl border border-gray-100">
        <p class="text-sm text-gray-600 italic mb-4">
          Berita ini diagregasi secara otomatis. Hak cipta sepenuhnya milik sumber asli.
        </p>
        <a 
          href={article.link} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg font-bold text-sm hover:bg-red-600 transition-all"
        >
          Baca Selengkapnya di {article.source} →
        </a>
      </div>
    </div>

    <div class="mt-16">
      <HilltopAd zoneId="YOUR_ZONE_ID_BOTTOM" height="250px" />
    </div>

  </article>
</Layout>
